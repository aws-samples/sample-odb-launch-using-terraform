# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default (may contain sensitive data)
*.tfvars
*.tfvars.json

# But include example tfvars (no secrets — SSH keys passed via CLI)
!examples/**/*.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Ignore backup files
*.backup
*.bak

# Ignore SSH keys
*.pem
*.key

# OS files
.DS_Store
Thumbs.db
